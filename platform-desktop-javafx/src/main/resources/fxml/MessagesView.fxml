<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Label?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="io.github.rygel.outerstellar.platform.fx.controller.MessagesController">
    <top>
        <HBox spacing="8" style="-fx-padding: 8;">
            <Label text="Search:"/>
            <TextField fx:id="searchField" HBox.hgrow="ALWAYS" promptText="Search messages..."/>
        </HBox>
    </top>
    <center>
        <ListView fx:id="messagesList"/>
    </center>
    <bottom>
        <VBox spacing="8" style="-fx-padding: 8;">
            <HBox spacing="8">
                <Label text="Author:"/>
                <TextField fx:id="authorField" HBox.hgrow="ALWAYS" promptText="Author name"/>
            </HBox>
            <TextArea fx:id="contentArea" prefRowCount="3" promptText="Message content..."/>
            <HBox spacing="8">
                <Button text="Create" onAction="#onCreateMessage"/>
                <Button text="Sync" onAction="#onSync"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
