<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="io.github.rygel.outerstellar.platform.fx.controller.AboutController"
      style="-fx-padding: 20;">
    <Label text="Outerstellar" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    <Label fx:id="versionLabel"/>
    <Separator/>
    <Label text="Licensed under the MIT License." wrapText="true"/>
    <Label text="Built with Kotlin, JavaFX, and AtlantaFX." wrapText="true"/>
    <HBox spacing="10">
        <Button text="Close" onAction="#onClose" cancelButton="true"/>
    </HBox>
</VBox>
