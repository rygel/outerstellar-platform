@import dev.outerstellar.starter.web.SidebarSelector
@param model: SidebarSelector

<div class="sidebar-select-wrapper">
    <h2>${model.heading}</h2>
    <label class="sidebar-select-label" for="${model.selectId}">${model.label}</label>
    <form hx-get="${model.refreshUrl}" hx-target="body" hx-push-url="true">
        <select id="${model.selectId}" name="${model.selectName}" class="sidebar-select" onchange="htmx.trigger(this.form, 'submit')">
            @for (option in model.options)
                <option value="${option.id}" selected="${option.active}">${option.label}</option>
            @endfor
        </select>
        @for (field in model.hiddenFields)
            <input type="hidden" name="${field.name}" value="${field.value}">
        @endfor
    </form>
</div>
