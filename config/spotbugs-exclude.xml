<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.jooq(\..*)?"/>
    </Match>
    <Match>
        <Package name="~gg\.jte\.generated(\..*)?"/>
    </Match>
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.swing(\..*)?"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.web.WebContext$Companion"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="~.*\$\$serializer"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Bug pattern="NP_LOAD_OF_KNOWN_NULL_VALUE"/>
    </Match>
    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
    </Match>
    <Match>
        <Bug pattern="THROWS_METHOD_THROWS_RUNTIMEEXCEPTION"/>
    </Match>
    <Match>
        <Bug pattern="BC_BAD_CAST_TO_ABSTRACT_COLLECTION"/>
    </Match>
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
    </Match>
    <Match>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
    </Match>
    <Match>
        <Bug pattern="SA_LOCAL_SELF_ASSIGNMENT"/>
    </Match>
    <!-- Kotlin when-expression with identical branches — false positive from generated bytecode -->
    <Match>
        <Bug pattern="DB_DUPLICATE_BRANCHES"/>
    </Match>
    <Match>
        <Bug pattern="BIT_AND_ZZ"/>
    </Match>
    <Match>
        <Bug pattern="RV_RETURN_VALUE_IGNORED_NO_SIDE_EFFECT"/>
    </Match>
</FindBugsFilter>
