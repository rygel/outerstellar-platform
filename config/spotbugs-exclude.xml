<?xml version="1.0" encoding="UTF-8"?>
<!--
    Outerstellar Platform — SpotBugs exclusion filter.

    Every entry below is documented with WHY it is correct. This file exists because SpotBugs analyzes
    JVM bytecode and cannot accurately model Kotlin idioms (elvis `?:`, `apply {}`, `use {}`, read-only
    `kotlin.collections.List`/`Map` vs mutable `java.util` interfaces), generated code (jOOQ, JTE,
    kotlinx.serialization), and intentional framework patterns (http4k lenses, DI component holders).

    POLICY (per AGENTS.md):
    - Do NOT add package-wide exclusions for NEW code. Add a class-specific match and document it here.
    - Do NOT suppress a finding to make it go away — first try to fix the root cause. Only suppress when
      the finding is a verified false positive or an unfixable framework/bytecode artifact.
    - Real bugs (null derefs, resource leaks, over-broad catches, dead code) must be FIXED in source,
      never hidden here.

    Sections:
      1. Generated code             — no hand-written source to fix
      2. Kotlin idiom false positives — SpotBugs can't model Kotlin control-flow/collection semantics
      3. Kotlin-collection exposure  — EI_EXPOSE_REP on `val List`/`Map` fields (read-only at JVM level edge)
      4. Companion-object false positives — MS_EXPOSE_REP on Kotlin `companion object` (per AGENTS.md)
      5. Interface contracts & intentional patterns
      6. Kotlin `use {}` resource analysis — SpotBugs can't follow the inlined try/finally
      7. Desktop / JavaFX scaffold  — platform-desktop-javafx is scaffolded, not production-ready
-->
<FindBugsFilter>

    <!-- ================================================================== -->
    <!-- 1. GENERATED CODE — no hand-written source to fix.                 -->
    <!-- ================================================================== -->

    <!-- jOOQ-generated DAOs/records/tables. Generated by jooq-codegen; regenerated on every schema change. -->
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.jooq(\..*)?"/>
    </Match>

    <!-- JTE precompiled template classes. Generated by the jte-maven-plugin from .kte templates. -->
    <Match>
        <Package name="~gg\.jte\.generated(\..*)?"/>
    </Match>

    <!-- kotlinx.serialization generated `$$serializer` companions. Compiler-generated; no source to edit. -->
    <Match>
        <Class name="~.*\$\$serializer"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>

    <!-- ================================================================== -->
    <!-- 2. KOTLIN IDIOM FALSE POSITIVES — SpotBugs can't model these.      -->
    <!--    Each pattern is a known SpotBugs/Kotlin bytecode-analysis gap.  -->
    <!-- ================================================================== -->

    <!-- Kotlin elvis `a ?: b ?: c` chains compile to null-check branches SpotBugs proves redundant on one path. -->
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
    </Match>
    <Match>
        <Bug pattern="NP_LOAD_OF_KNOWN_NULL_VALUE"/>
    </Match>

    <!-- `HikariConfig().apply { this.x = x }` — SpotBugs reads the inlined `this.x = x` as a self-assignment. -->
    <Match>
        <Bug pattern="SA_LOCAL_SELF_ASSIGNMENT"/>
    </Match>

    <!-- Kotlin `var x: T` declared then assigned in a loop body. Kept narrow: real dead stores must be fixed. -->
    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
    </Match>

    <!-- Intentional broad catches that rethrow/translate exist (e.g. OutboxProcessor, StaticRoutes) and are
         annotated @Suppress("TooGenericExceptionCaught") at the Kotlin level; SpotBugs still flags them. -->
    <Match>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
    </Match>

    <!-- Atomic-counter return values (.incrementAndGet()) and http4k fluent builders: return intentionally ignored. -->
    <Match>
        <Bug pattern="RV_RETURN_VALUE_IGNORED_NO_SIDE_EFFECT"/>
    </Match>

    <!-- `&&` lowering on platform string intrinsics emits bytecode SpotBugs reads as `&` on booleans. -->
    <Match>
        <Bug pattern="BIT_AND_ZZ"/>
    </Match>

    <!-- Kotlin data-class constructor param → field copy (`val x = x.toList()`) still flagged even when defended. -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- ================================================================== -->
    <!-- 3. KOTLIN-COLLECTION EXPOSURE — EI_EXPOSE_REP on `val List`/`Map`. -->
    <!--    Kotlin's read-only `List`/`Map` map to `java.util` interfaces at the JVM level, so SpotBugs    -->
    <!--    treats property getters as exposing mutable state. The underlying Kotlin collections are        -->
    <!--    immutable by contract. Established in PR #501. Package-wide excludes are retained for legacy   -->
    <!--    packages; NEW code must use a class-specific match + comment, not a package exclude.           -->
    <!-- ================================================================== -->

    <!-- Legacy package-wide excludes (established packages of data classes / DTOs with `val` collections). -->
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.model(\..*)?"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.sync(\..*)?"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.web(\..*)?"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.extension(\..*)?"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.infra(\..*)?"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!-- Named classes with `val List`/`Map` properties (config / DTOs / http4k lens singletons). -->
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.RouteHeaderOverride"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.SecurityHeadersConfig"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.service.PushNotification"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- SecurityRules holds an immutable http4k RequestKey lens shared as a singleton — canonical declaration. -->
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.security.SecurityRules"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- ContactExportRow is a @Serializable DTO with `val emails: List<String>`. SpotBugs flags the generated
         component2()/getEmails() accessors; Kotlin's List is read-only by contract. (The provider builds each
         row with a defensive .toList() copy at the construction site — see ContactExportProvider.kt.) -->
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.export.ContactExportProvider$ContactExportRow"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!-- DI component holders expose immutable singleton handles (services/repos). These are read-only handles
         to shared singletons by design; defensive-copying would be semantically wrong. -->
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.di.CoreComponents"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.di.PersistenceComponents"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.security.SecurityComponents"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.ServerComponents"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.di.WebComponents"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!-- ================================================================== -->
    <!-- 4. COMPANION-OBJECT FALSE POSITIVES — MS_EXPOSE_REP on              -->
    <!--    `companion object` (AGENTS.md: known SpotBugs/Kotlin false positive). -->
    <!-- ================================================================== -->

    <Match>
        <Class name="io.github.rygel.outerstellar.platform.web.WebContext$Companion"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.web.RequestContext$Companion"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.web.ShellRenderer$Companion"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.security.PasswordResetService$Companion"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.i18n.Language$Companion"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>

    <!-- WebContext has a private method SpotBugs reports as uncalled; it is invoked reflectively by http4k. -->
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.web.WebContext"/>
        <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD"/>
    </Match>

    <!-- ================================================================== -->
    <!-- 5. INTERFACE CONTRACTS & INTENTIONAL PATTERNS                     -->
    <!-- ================================================================== -->

    <!-- CompositeCodeResolver returns MutableList because the jte CodeResolver interface declares it; the
         returned list is a fresh defensive copy. -->
    <Match>
        <Bug pattern="BC_BAD_CAST_TO_ABSTRACT_COLLECTION"/>
    </Match>

    <!-- ConflictResolution `when` arm: both `"server" -> SERVER` and `else -> SERVER` deliberately yield the
         same value (default-to-SERVER semantics). Collapsing would lose the explicit mapping. -->
    <Match>
        <Bug pattern="DB_DUPLICATE_BRANCHES"/>
    </Match>

    <!-- ================================================================== -->
    <!-- 6. KOTLIN `use {}` RESOURCE ANALYSIS — SpotBugs can't follow the   -->
    <!--    inlined try/finally, so it reports JDBC Connection/PreparedStatement -->
    <!--    obligations as unmet. Resources ARE correctly closed by `use {}`.   -->
    <!-- ================================================================== -->

    <Match>
        <Class name="io.github.rygel.outerstellar.platform.infra.DatabaseInfraKt"/>
        <Bug pattern="OBL_UNSATISFIED_OBLIGATION"/>
    </Match>
    <!-- Bare `return` in a Unit-returning function emits a label-jump SpotBugs reads as useless control flow. -->
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.infra.DatabaseInfraKt"/>
        <Bug pattern="UCF_USELESS_CONTROL_FLOW_NEXT_LINE"/>
    </Match>

    <!-- ================================================================== -->
    <!-- 7. DESKTOP / JAVAFX SCAFFOLD                                       -->
    <!-- platform-desktop-javafx is scaffolded, not production-ready (AGENTS.md). -->
    <!-- platform-desktop (Swing) is production but UI-toolkit-heavy; the package-wide exclude is retained. -->
    <!-- ================================================================== -->

    <!-- Swing UI toolkit code: heavy AWT/Swing interaction SpotBugs models poorly. -->
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.swing(\..*)?"/>
    </Match>

    <!-- Desktop DI components (mirrors the server-side DI holders in section 3). -->
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.di.DesktopComponents"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.di.HttpClients"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.di.SyncModules"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- DesktopComponentsKt top-level functions: builder null-path findings SpotBugs can't resolve. -->
    <Match>
        <Class name="~io\.github\.rygel\.outerstellar\.platform\.di\.DesktopComponentsKt"/>
        <Bug pattern="NP_NULL_ON_SOME_PATH"/>
    </Match>
    <Match>
        <Class name="~io\.github\.rygel\.outerstellar\.platform\.di\.DesktopComponentsKt"/>
        <Bug pattern="NP_NULL_PARAM_DEREF"/>
    </Match>

    <!-- JavaFX scaffold (platform-desktop-javafx) — not production-ready; findings deferred until the
         module is promoted. Grouped here so they can be re-evaluated as a batch. -->
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.fx(\..*)?"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.fx\.controller(\..*)?"/>
        <Bug pattern="NP_NULL_ON_SOME_PATH"/>
    </Match>
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.fx\.controller(\..*)?"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.fx\.controller(\..*)?"/>
        <Bug pattern="BC_UNCONFIRMED_CAST_OF_RETURN_VALUE"/>
    </Match>
    <Match>
        <Package name="~io\.github\.rygel\.outerstellar\.platform\.fx\.controller(\..*)?"/>
        <Bug pattern="UPM_UNCALLED_PRIVATE_METHOD"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.fx.service.FxTrayNotifier"/>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.fx.app.JavaFxApp"/>
        <Bug pattern="NP_NULL_ON_SOME_PATH"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.fx.app.JavaFxApp"/>
        <Bug pattern="NP_NULL_ON_SOME_PATH_MIGHT_BE_INFEASIBLE"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.fx.app.JavaFxApp"/>
        <Bug pattern="NP_NULL_PARAM_DEREF"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.fx.FxAppContext"/>
        <Bug pattern="NP_NULL_ON_SOME_PATH"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.fx.FxAppContext"/>
        <Bug pattern="NP_NULL_PARAM_DEREF"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.fx.FxAppContext"/>
        <Bug pattern="NP_NONNULL_RETURN_VIOLATION"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.fx.FxAppContext"/>
        <Bug pattern="MS_PKGPROTECT"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.fx.FxAppContext"/>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.fx.FxAppContext"/>
        <Bug pattern="PA_PUBLIC_PRIMITIVE_ATTRIBUTE"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.fx.FxAppContext"/>
        <Bug pattern="URF_UNREAD_FIELD"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.fx.viewmodel.FxSyncViewModel"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="io.github.rygel.outerstellar.platform.fx.viewmodel.FxSyncViewModel"/>
        <Bug pattern="URF_UNREAD_FIELD"/>
    </Match>

</FindBugsFilter>
