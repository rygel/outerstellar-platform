@import dev.outerstellar.platform.web.ShellView
@import gg.jte.Content
@param shell: ShellView
@param content: Content

@if(shell.layoutStyle == "topbar")
    @template.dev.outerstellar.platform.web.layouts.TopbarLayout(shell = shell, content = content)
@else
    @template.dev.outerstellar.platform.web.layouts.SidebarLayout(shell = shell, content = content)
@endif
