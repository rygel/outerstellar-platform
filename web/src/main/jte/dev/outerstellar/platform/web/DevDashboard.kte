@import dev.outerstellar.platform.web.DevDashboardPage
@import dev.outerstellar.platform.web.Page
@param model: Page<DevDashboardPage>

@template.dev.outerstellar.platform.web.LayoutRouter(shell = model.shell, content = @`
    <section class="panel hero-grid">
        <div>
            <p class="status-badge">${model.data.badge}</p>
            <h1>${model.data.heading}</h1>
            <p>${model.data.description}</p>
        </div>
    </section>

    <div class="card-grid">
        <section class="panel">
            <h2>${model.data.outboxLabel}</h2>
            <div class="message-list">
                <div class="message-meta">
                    <span>${model.data.pendingLabel}</span>
                    <strong>${model.data.outboxStats.pending}</strong>
                </div>
                <div class="message-meta">
                    <span>${model.data.processedLabel}</span>
                    <strong>${model.data.outboxStats.processed}</strong>
                </div>
                <div class="message-meta">
                    <span>${model.data.failedLabel}</span>
                    <strong>${model.data.outboxStats.failed}</strong>
                </div>
            </div>
        </section>

        <section class="panel">
            <h2>${model.data.cacheLabel}</h2>
            <div class="message-list">
                @for(entry in model.data.cacheStats)
                    <div class="message-meta">
                        <span>${entry.key}</span>
                        <strong>${entry.value.toString()}</strong>
                    </div>
                @endfor
            </div>
        </section>
    </div>

    <section class="panel">
        <h2>${model.data.protocolLabel}</h2>
        <p class="opacity-70 mb-4">Test the <code>outerstellar://</code> deep link integration with the desktop application.</p>
        <div class="button-row">
            <a href="outerstellar://sync" class="button-link">${model.data.triggerSyncLabel}</a>
            <a href="outerstellar://search?q=HTMX" class="button-link button-secondary">Search "HTMX"</a>
            <a href="outerstellar://search?q=Dracula" class="button-link button-secondary">Search "Dracula"</a>
        </div>
    </section>

    <section class="panel">
        <h2>${model.data.telemetryLabel}</h2>
        <p class="status-badge">${model.data.telemetryStatus}</p>
    </section>

    <section class="panel">
        <h2>${model.data.metricsLabel}</h2>
        <pre class="panel panel-muted" style="overflow: auto; max-height: 400px; font-size: 12px; font-family: monospace;">
${model.data.metrics}
        </pre>
    </section>
`)
