@import gg.jte.Content
@param id: String
@param maxWidth: String = "max-w-md"
@param content: Content

<div id="${id}" class="modal-overlay fixed inset-0 z-[1000] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
     onclick="if(event.target === this) this.remove()">
    <div class="panel ${maxWidth} w-full animate-in fade-in zoom-in duration-200" onclick="event.stopPropagation()">
        ${content}
    </div>
</div>
