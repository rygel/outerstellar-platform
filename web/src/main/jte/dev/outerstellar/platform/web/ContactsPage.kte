@import dev.outerstellar.platform.web.ContactsPage
@import dev.outerstellar.platform.web.Page

@param model: Page<ContactsPage>

@template.dev.outerstellar.platform.web.Layout(shell = model.shell, content = @`
    @template.dev.outerstellar.platform.web.components.PageHeader(
        title = model.data.title,
        description = model.data.description,
        action = @`
            <button class="button-accent"
                    hx-get="/contacts/new"
                    hx-target="body"
                    hx-swap="beforeend">
                <i class="ri-user-add-line"></i>
                ${model.data.createLabel}
            </button>
        `
    )

    <div id="contact-list-container">
        <div class="card-grid">
            @for (contact in model.data.contacts)
                <div id="contact-${contact.syncId}" class="panel contact-card">
                    <div class="contact-header">
                        <div class="contact-avatar">
                            ${contact.name.take(1).uppercase()}
                        </div>
                        <div class="contact-info">
                            <h3>${contact.name}</h3>
                            <p class="text-muted">${contact.company} &middot; ${contact.department}</p>
                        </div>
                    </div>

                    <div class="contact-details mt-4">
                        <div class="contact-detail-item">
                            <i class="ri-mail-line"></i>
                            <div>
                                @for (email in contact.emails)
                                    <div>${email}</div>
                                @endfor
                            </div>
                        </div>
                        <div class="contact-detail-item">
                            <i class="ri-phone-line"></i>
                            <div>
                                @for (phone in contact.phones)
                                    <div>${phone}</div>
                                @endfor
                            </div>
                        </div>
                        @if (contact.socialMedia.isNotEmpty())
                            <div class="contact-detail-item">
                                <i class="ri-share-line"></i>
                                <div class="flex gap-2">
                                    @for (social in contact.socialMedia)
                                        <span class="chip">${social}</span>
                                    @endfor
                                </div>
                            </div>
                        @endif
                        <div class="contact-detail-item">
                            <i class="ri-map-pin-line"></i>
                            <div>${contact.companyAddress}</div>
                        </div>
                    </div>

                    <div class="flex justify-end gap-2 mt-6">
                        <button class="button-icon" title="${model.data.editTitle}"
                                hx-get="${contact.editUrl}"
                                hx-target="body"
                                hx-swap="beforeend">
                            <i class="ri-edit-line"></i>
                        </button>
                        <button class="button-icon text-danger" title="${model.data.deleteTitle}"
                                hx-post="${contact.deleteUrl}"
                                hx-target="#contact-${contact.syncId}"
                                hx-swap="outerHTML"
                                hx-confirm="${model.data.deleteConfirmLabel}">
                            <i class="ri-delete-bin-line"></i>
                        </button>
                    </div>
                </div>
            @endfor
        </div>

        @template.dev.outerstellar.platform.web.components.Pagination(
            hasPrevious = model.data.hasPrevious,
            hasNext = model.data.hasNext,
            previousUrl = model.data.previousUrl,
            nextUrl = model.data.nextUrl,
            currentPage = model.data.currentPage,
            previousLabel = model.data.previousPageTitle,
            nextLabel = model.data.nextPageTitle,
            totalCount = model.data.totalCount,
            totalCountLabel = model.data.contactsTotalLabel
        )
    </div>
`)
