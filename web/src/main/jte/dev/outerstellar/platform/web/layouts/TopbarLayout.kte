@import dev.outerstellar.platform.web.ShellView
@import gg.jte.Content
@param shell: ShellView
@param content: Content

<!DOCTYPE html>
<html lang="${shell.localeTag}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="${shell.csrfToken}">
    <title>${shell.pageTitle} - ${shell.appTitle}</title>
    <link href="/vendor/remixicon/remixicon.css" rel="stylesheet" />
    <link rel="stylesheet" href="/site.css?v=${shell.version}">
    <script src="/vendor/htmx.min.js"></script>
    <script src="/vendor/htmx-ext-ws.js"></script>
    <style>
        .htmx-indicator { display: none; }
        .htmx-request .htmx-indicator { display: inline-block; }
        .htmx-request.htmx-indicator { display: inline-block; }

        #toast-container {
            position: fixed;
            top: 1.5rem;
            right: 1.5rem;
            z-index: 9999;
            pointer-events: none;
            width: 320px;
        }

        /* Topbar layout overrides */
        .topbar-shell {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        .topbar-nav {
            display: flex;
            align-items: center;
            gap: 0;
            background: var(--color-surface);
            border-bottom: 1px solid var(--color-border);
            padding: 0 1.5rem;
            height: 56px;
            flex-shrink: 0;
        }
        .topbar-nav .logo {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 700;
            font-size: 1rem;
            text-decoration: none;
            color: var(--color-text);
            margin-right: 2rem;
            white-space: nowrap;
        }
        .topbar-nav .nav-links-row {
            display: flex;
            align-items: stretch;
            gap: 0;
            flex: 1;
        }
        .topbar-nav .nav-link {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0 1rem;
            height: 56px;
            font-size: 0.875rem;
            text-decoration: none;
            color: var(--color-text-muted);
            border-bottom: 2px solid transparent;
            white-space: nowrap;
            transition: color 0.15s, border-color 0.15s;
        }
        .topbar-nav .nav-link:hover { color: var(--color-text); }
        .topbar-nav .nav-link.active {
            color: var(--color-accent);
            border-bottom-color: var(--color-accent);
        }
        .topbar-nav .nav-actions {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-left: auto;
        }
        .topbar-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .topbar-content {
            flex: 1;
            padding: 1.5rem;
            overflow-y: auto;
        }
        .topbar-footer {
            display: flex;
            align-items: center;
            padding: 0.75rem 1.5rem;
            font-size: 0.8rem;
            color: var(--color-text-muted);
            border-top: 1px solid var(--color-border);
            background: var(--color-surface);
        }
        .topbar-user-info {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.875rem;
        }
    </style>
</head>
<body class="${shell.layoutClass}" hx-ext="ws" ws-connect="/ws/sync">
<style id="theme-style">${shell.themeCss}</style>
<div id="toast-container"></div>
<script>
    document.addEventListener('htmx:responseError', function(event) {
        const errorBody = event.detail.xhr.responseText || 'An unexpected error occurred';
        showToast(errorBody, 'error');
    });

    function showToast(message, type) {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        toast.className = "panel animate-in slide-in-from-right-10 fade-in duration-300 " + (type === 'error' ? 'panel-danger' : 'panel-success');
        toast.style.padding = '0.75rem 1.25rem';
        toast.style.marginBottom = '0.75rem';
        toast.style.pointerEvents = 'auto';
        toast.style.boxShadow = '0 10px 15px -3px rgba(0, 0, 0, 0.1)';

        const title = type === 'error' ? '${shell.toastErrorLabel}' : '${shell.toastSuccessLabel}';
        const icon = type === 'error' ? 'ri-error-warning-fill' : 'ri-checkbox-circle-fill';

        const row = document.createElement('div');
        row.style.cssText = 'display: flex; align-items: center; gap: 0.75rem;';

        const iconEl = document.createElement('i');
        iconEl.className = icon;
        iconEl.style.fontSize = '1.25rem';

        const textEl = document.createElement('div');
        const titleEl = document.createElement('strong');
        titleEl.style.cssText = 'display: block; font-size: 0.9rem;';
        titleEl.textContent = title;
        const msgEl = document.createElement('p');
        msgEl.style.cssText = 'margin:0; font-size: 0.85rem; opacity: 0.9;';
        msgEl.textContent = message;
        textEl.appendChild(titleEl);
        textEl.appendChild(msgEl);
        row.appendChild(iconEl);
        row.appendChild(textEl);
        toast.appendChild(row);

        container.appendChild(toast);
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(20px)';
            toast.style.transition = 'all 0.3s ease-out';
            setTimeout(() => toast.remove(), 300);
        }, 5000);
    }
</script>
<div class="topbar-shell">
    <nav class="topbar-nav">
        <a href="/" class="logo">
            <i class="ri-planet-fill"></i>
            ${shell.appTitle}
        </a>
        <div class="nav-links-row">
            @for(link in shell.navLinks)
                <a class="nav-link@if(link.active) active@endif" href="${link.url}">
                    <i class="${link.icon}"></i>
                    ${link.label}
                </a>
            @endfor
        </div>
        <div class="nav-actions">
            <a href="${shell.darkModeToggleUrl}"
               class="button-icon"
               title="Toggle dark/light mode"
               style="text-decoration: none; font-size: 1.1rem;">
                @if(shell.isDarkMode)
                    <i class="ri-sun-line"></i>
                @else
                    <i class="ri-moon-line"></i>
                @endif
            </a>
            @if(shell.notificationsUrl != null)
                <div id="notification-bell"
                     hx-get="/components/notification-bell"
                     hx-trigger="load, every 60s"
                     hx-swap="innerHTML">
                </div>
            @endif
            @if(shell.isLoggedIn)
                <div class="topbar-user-info">
                    <span style="opacity: 0.7;">${shell.userName}</span>
                    @if(shell.profileUrl != null)
                        <a href="${shell.profileUrl}" class="sign-out-link" style="font-size:0.8rem;"><i class="ri-user-settings-line"></i></a>
                    @endif
                    @if(shell.changePasswordUrl != null)
                        <a href="${shell.changePasswordUrl}" class="sign-out-link" style="font-size:0.8rem;"><i class="ri-lock-password-line"></i></a>
                    @endif
                    <form method="post" action="${shell.logoutUrl}" style="display:inline;">
                        <input type="hidden" name="_csrf" value="${shell.csrfToken}">
                        <button type="submit" class="sign-out-link" style="background:none;border:none;padding:0;cursor:pointer;font-size:0.8rem;">${shell.signOutLabel}</button>
                    </form>
                </div>
            @endif
        </div>
    </nav>
    <div class="topbar-main">
        <main class="topbar-content ${shell.layoutClass}">
            <div id="ws-updates" ws-subscribe></div>
            ${content}
        </main>
        <footer class="topbar-footer">
            <span>${shell.footerCopy}</span>
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-left: auto;">
                <span style="opacity: 0.6; font-size: 0.8rem;">${shell.footerVersion}</span>
                <div id="footer-status"
                     class="chip"
                     hx-get="${shell.footerStatusUrl}"
                     hx-trigger="load"
                     hx-swap="innerHTML">
                </div>
            </div>
        </footer>
    </div>
</div>
<script>
    document.addEventListener('htmx:configRequest', function(event) {
        var token = document.querySelector('meta[name="csrf-token"]');
        if (token) {
            event.detail.headers['X-CSRF-Token'] = token.content;
        }
    });
</script>
<script>
    (function() {
        var hasCookie = document.cookie.split(';').some(function(c) {
            return c.trim().startsWith('app_theme=');
        });
        if (!hasCookie && window.matchMedia) {
            var prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
            if (prefersLight) {
                var expires = new Date(Date.now() + 365 * 86400 * 1000).toUTCString();
                document.cookie = 'app_theme=default;path=/;expires=' + expires;
                window.location.reload();
            }
        }
    })();
</script>
</body>
</html>
