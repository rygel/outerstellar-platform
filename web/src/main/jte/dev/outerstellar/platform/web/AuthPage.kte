@import dev.outerstellar.platform.web.AuthViewModel
@import dev.outerstellar.platform.web.Page
@param model: Page<AuthViewModel>

@template.dev.outerstellar.platform.web.Layout(shell = model.shell, content = @`
    <section class="hero-grid">
        <div class="panel">
            <p class="topbar-label">${model.shell.pageTitle}</p>
            <h1>${model.data.heading}</h1>
            <p class="text-muted">${model.data.intro}</p>
        </div>
    </section>
    
    <div style="max-width: 500px; margin: 2rem auto;">
        <section class="panel">
            <div class="tabs mb-6" style="display: flex; gap: 0.5rem; justify-content: center;">
                @for (tab in model.data.tabs)
                    <button class="secondary"
                            style="flex: 1;"
                            hx-get="${tab.url}"
                            hx-target="#auth-form-slot"
                            hx-swap="innerHTML">
                        ${tab.label}
                    </button>
                @endfor
            </div>
            <div id="auth-form-slot"
                 hx-get="${model.data.defaultFormUrl}"
                 hx-trigger="load"
                 hx-swap="innerHTML">
            </div>
            <div id="auth-result-slot" class="mt-4"></div>
        </section>
        
        <div class="panel panel-muted mt-6 text-center">
            <p class="text-muted" style="margin: 0;">${model.data.helperText}</p>
        </div>
    </div>
`)
