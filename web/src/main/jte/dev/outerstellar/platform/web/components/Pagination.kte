@import dev.outerstellar.platform.web.PageNumberViewModel
@param hasPrevious: Boolean
@param hasNext: Boolean
@param previousUrl: String
@param nextUrl: String
@param currentPage: Int
@param previousLabel: String = "Previous page"
@param nextLabel: String = "Next page"
@param totalCount: Long = 0L
@param totalCountLabel: String = ""
@param hxTarget: String = ""
@param pages: List<PageNumberViewModel> = emptyList()
@param totalPages: Int = 0
@param showingPageLabel: String = ""
@param ofLabel: String = ""

@if(hasPrevious || hasNext)
<div class="pagination-nav">
    <span class="pagination-info">
        @if(showingPageLabel.isNotEmpty() && totalPages > 0)
            ${showingPageLabel} <strong>${currentPage}</strong> ${ofLabel} <strong>${totalPages}</strong>
        @elseif(totalCount > 0 && totalCountLabel.isNotEmpty())
            Page ${currentPage} &middot; ${totalCount} ${totalCountLabel}
        @else
            Page ${currentPage}
        @endif
    </span>
    <div class="flex gap-2">
        @if(hasPrevious)
            @if(hxTarget.isNotEmpty())
                <button class="button-icon" title="${previousLabel}"
                        hx-get="${previousUrl}"
                        hx-target="${hxTarget}"
                        hx-push-url="true">
                    <i class="ri-arrow-left-s-line"></i>
                </button>
            @else
                <a href="${previousUrl}" class="button-icon" title="${previousLabel}">
                    <i class="ri-arrow-left-s-line"></i>
                </a>
            @endif
        @else
            <button class="button-icon" disabled style="opacity: 0.3; cursor: not-allowed;">
                <i class="ri-arrow-left-s-line"></i>
            </button>
        @endif
        @for(page in pages)
            @if(hxTarget.isNotEmpty())
                <button class="button-icon @if(page.isActive) border-accent text-accent font-bold @endif"
                        hx-get="${page.url}"
                        hx-target="${hxTarget}"
                        hx-push-url="true">
                    ${page.number}
                </button>
            @else
                <a href="${page.url}" class="button-icon @if(page.isActive) border-accent text-accent font-bold @endif">
                    ${page.number}
                </a>
            @endif
        @endfor
        @if(hasNext)
            @if(hxTarget.isNotEmpty())
                <button class="button-icon" title="${nextLabel}"
                        hx-get="${nextUrl}"
                        hx-target="${hxTarget}"
                        hx-push-url="true">
                    <i class="ri-arrow-right-s-line"></i>
                </button>
            @else
                <a href="${nextUrl}" class="button-icon" title="${nextLabel}">
                    <i class="ri-arrow-right-s-line"></i>
                </a>
            @endif
        @else
            <button class="button-icon" disabled style="opacity: 0.3; cursor: not-allowed;">
                <i class="ri-arrow-right-s-line"></i>
            </button>
        @endif
    </div>
</div>
@endif
