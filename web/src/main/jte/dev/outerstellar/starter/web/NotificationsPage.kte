@import dev.outerstellar.starter.web.NotificationsPage
@import dev.outerstellar.starter.web.Page
@param model: Page<NotificationsPage>

@template.dev.outerstellar.starter.web.Layout(shell = model.shell, content = @`
    <div style="max-width: 760px; margin: 0 auto;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
            <div>
                <h2 style="margin:0;">${model.data.title}</h2>
                <p style="margin:0.25rem 0 0; opacity:0.65; font-size:0.9rem;">${model.data.description}</p>
            </div>
            @if(model.data.unreadCount > 0)
                <form method="post" action="${model.data.markAllReadUrl}">
                    <input type="hidden" name="_csrf" value="${model.shell.csrfToken}">
                    <button type="submit" class="button-secondary" style="font-size:0.85rem;">
                        <i class="ri-check-double-line"></i> ${model.data.markAllReadLabel}
                    </button>
                </form>
            @endif
        </div>

        @if(model.data.notifications.isEmpty())
            <div class="panel panel-muted" style="text-align:center; padding:3rem;">
                <i class="ri-notification-off-line" style="font-size:2.5rem; opacity:0.3;"></i>
                <p style="margin:0.75rem 0 0; opacity:0.5;">${model.data.emptyLabel}</p>
            </div>
        @else
            <div style="display:flex; flex-direction:column; gap:0.75rem;">
                @for(n in model.data.notifications)
                    <div class="panel@if(!n.read) panel-accent@endif"
                         style="display:flex; align-items:flex-start; gap:1rem; padding:1rem 1.25rem;">
                        <div style="padding-top:0.15rem;">
                            @if(n.type == "success")
                                <i class="ri-checkbox-circle-line" style="color:var(--color-success, #22c55e); font-size:1.2rem;"></i>
                            @elseif(n.type == "warning")
                                <i class="ri-alert-line" style="color:var(--color-warning, #f59e0b); font-size:1.2rem;"></i>
                            @elseif(n.type == "danger")
                                <i class="ri-error-warning-line" style="color:var(--color-danger, #ef4444); font-size:1.2rem;"></i>
                            @else
                                <i class="ri-information-line" style="color:var(--color-accent, #6366f1); font-size:1.2rem;"></i>
                            @endif
                        </div>
                        <div style="flex:1; min-width:0;">
                            <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                                <strong style="font-size:0.95rem;">${n.title}</strong>
                                @if(!n.read)
                                    <span class="chip" style="font-size:0.7rem; padding:0.1rem 0.4rem;">New</span>
                                @endif
                                <span style="opacity:0.45; font-size:0.8rem; margin-left:auto;">${n.timeAgo}</span>
                            </div>
                            <p style="margin:0.25rem 0 0; font-size:0.875rem; opacity:0.8;">${n.body}</p>
                        </div>
                        @if(!n.read)
                            <form method="post" action="${n.markReadUrl}" style="flex-shrink:0;">
                                <input type="hidden" name="_csrf" value="${model.shell.csrfToken}">
                                <button type="submit" class="button-ghost" style="font-size:0.8rem; padding:0.3rem 0.6rem;"
                                        title="${model.data.markReadLabel}">
                                    <i class="ri-check-line"></i>
                                </button>
                            </form>
                        @else
                            <span style="opacity:0.3; font-size:0.8rem; flex-shrink:0;">${model.data.readLabel}</span>
                        @endif
                    </div>
                @endfor
            </div>
        @endif
    </div>
`)
