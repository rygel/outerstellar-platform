@import dev.outerstellar.starter.web.ModalViewModel
@param model: ModalViewModel

<div id="${model.id}" class="modal-overlay fixed inset-0 z-[1000] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
     onclick="if(event.target === this) this.remove()">
    <div class="panel max-w-md w-full animate-in fade-in zoom-in duration-200" onclick="event.stopPropagation()">
        <h3 class="text-xl font-bold mb-2">${model.title}</h3>
        <p class="opacity-70 mb-6">${model.message}</p>
        
        <div class="flex justify-end gap-3">
            <button class="button-link button-secondary" onclick="document.getElementById('${model.id}').remove()">
                ${model.cancelLabel}
            </button>
            <button class="button-link bg-danger hover:bg-danger/90 border-none"
                    hx-delete="${model.actionUrl}"
                    hx-target="${model.targetId}"
                    hx-swap="outerHTML"
                    onclick="document.getElementById('${model.id}').remove()">
                ${model.confirmLabel}
            </button>
        </div>
    </div>
</div>
