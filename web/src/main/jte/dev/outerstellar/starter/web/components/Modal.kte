@param id: String
@param title: String
@param message: String
@param confirmLabel: String = "Confirm"
@param cancelLabel: String = "Cancel"
@param actionUrl: String
@param targetId: String

<div id="${id}" class="modal-overlay fixed inset-0 z-[1000] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
     onclick="if(event.target === this) this.remove()">
    <div class="panel max-w-md w-full animate-in fade-in zoom-in duration-200" onclick="event.stopPropagation()">
        <h3 class="text-xl font-bold mb-2">${title}</h3>
        <p class="opacity-70 mb-6">${message}</p>
        
        <div class="flex justify-end gap-3">
            <button class="button-link button-secondary" onclick="document.getElementById('${id}').remove()">
                ${cancelLabel}
            </button>
            <button class="button-link bg-danger hover:bg-danger/90 border-none"
                    hx-delete="${actionUrl}"
                    hx-target="${targetId}"
                    hx-swap="outerHTML"
                    onclick="document.getElementById('${id}').remove()">
                ${confirmLabel}
            </button>
        </div>
    </div>
</div>
