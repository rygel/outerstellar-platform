@import dev.outerstellar.starter.web.ChangePasswordPage
@import dev.outerstellar.starter.web.Page
@param model: Page<ChangePasswordPage>

@template.dev.outerstellar.starter.web.Layout(shell = model.shell, content = @`
    <div style="max-width: 500px; margin: 2rem auto;">
        <section class="panel">
            <div id="change-password-form">
                @template.dev.outerstellar.starter.web.ChangePasswordForm(model = model.data.form)
            </div>
            <div id="auth-result-slot" class="mt-4"></div>
        </section>
    </div>
`)
