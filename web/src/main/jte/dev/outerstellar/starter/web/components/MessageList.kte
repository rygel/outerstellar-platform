@import dev.outerstellar.starter.web.MessageListViewModel
@param model: MessageListViewModel

<div id="message-list-panel">
    <div class="message-list">
        @if(model.messages.isEmpty())
            <div class="empty-state panel">
                <p>${model.emptyMessage}</p>
            </div>
        @else
            @for(message in model.messages)
                <div class="message-card panel">
                    <div class="message-header">
                        <span class="message-author">${message.author}</span>
                        <span class="message-time">${message.updatedAtLabel()}</span>
                    </div>
                    <div class="message-content">
                        ${message.content}
                    </div>
                    <div class="message-actions">
                        <button class="button-icon button-danger"
                                hx-delete="${model.deleteUrl}/${message.syncId}"
                                hx-confirm="Are you sure you want to delete this message?"
                                hx-target="#message-list-panel"
                                hx-swap="outerHTML"
                                title="Delete Message">
                            <i class="ri-delete-bin-line"></i>
                        </button>
                    </div>
                </div>
            @endfor
        @endif
    </div>

    @if(model.pagination != null)
        <nav class="pagination-bar" style="display: flex; justify-content: center; gap: 0.5rem; margin-top: 2rem;">
            @if(model.pagination.hasPrevious)
                <button class="button-secondary"
                        hx-get="${model.pagination.previousUrl}"
                        hx-target="#message-list-panel"
                        hx-swap="outerHTML"
                        hx-push-url="true">
                    <i class="ri-arrow-left-s-line"></i>
                </button>
            @endif

            @for(page in model.pagination.pages)
                <button class="${if (page.isActive) "button-primary" else "button-secondary"}"
                        hx-get="${page.url}"
                        hx-target="#message-list-panel"
                        hx-swap="outerHTML"
                        hx-push-url="true">
                    ${page.number}
                </button>
            @endfor

            @if(model.pagination.hasNext)
                <button class="button-secondary"
                        hx-get="${model.pagination.nextUrl}"
                        hx-target="#message-list-panel"
                        hx-swap="outerHTML"
                        hx-push-url="true">
                    <i class="ri-arrow-right-s-line"></i>
                </button>
            @endif
        </nav>
    @endif
</div>
