@import dev.outerstellar.starter.web.MessageListViewModel
@import java.time.LocalDate
@param model: MessageListViewModel

<section class="panel" id="message-list-panel">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
        <h2>${model.messagesHeading}</h2>
        <form method="get" action="/" 
              hx-get="${model.fragmentUrl}" 
              hx-target="#message-list-panel" 
              hx-swap="outerHTML" 
              hx-push-url="true"
              hx-trigger="submit, change from:select[name='year']"
              class="flex flex-wrap gap-2">
            
            <select name="year" class="px-3 py-1 border rounded bg-white">
                <option value="">All Years</option>
                @for(year in LocalDate.now().getYear() downTo 2024)
                    <option value="${year}" selected="${model.selectedYear == year}">${year}</option>
                @endfor
            </select>

            <input type="text" name="q" value="${model.searchQuery}" placeholder="Search messages..." class="px-3 py-1 border rounded">
            <input type="hidden" name="limit" value="${model.limit}">
            <button type="submit" class="px-4 py-1 bg-blue-600 text-white rounded">Search</button>
        </form>
    </div>
    <div class="message-list">
        @if(model.messages.isEmpty())
            <div class="py-10 text-center text-gray-500">
                No messages found.
            </div>
        @else
            @for (message in model.messages)
                <article class="message-card">
                    <div class="message-meta">
                        <strong>${message.author}</strong>
                        <span>${message.updatedAtLabel()}</span>
                    </div>
                    <p>${message.content}</p>
                    <span class="status-badge">${message.syncStatusLabel()}</span>
                </article>
            @endfor
        @endif
    </div>
    <div class="flex justify-between mt-6">
        @if(model.prevOffset != null)
            <a href="/?q=${if (model.searchQuery != null) model.searchQuery else ""}&year=${if (model.selectedYear != null) model.selectedYear.toString() else ""}&offset=${model.prevOffset}&limit=${model.limit}" 
               hx-get="${model.fragmentUrl}?q=${if (model.searchQuery != null) model.searchQuery else ""}&year=${if (model.selectedYear != null) model.selectedYear.toString() else ""}&offset=${model.prevOffset}&limit=${model.limit}"
               hx-target="#message-list-panel"
               hx-swap="outerHTML"
               hx-push-url="true"
               class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">Previous</a>
        @else
            <span></span>
        @endif

        @if(model.nextOffset != null)
            <a href="/?q=${if (model.searchQuery != null) model.searchQuery else ""}&year=${if (model.selectedYear != null) model.selectedYear.toString() else ""}&offset=${model.nextOffset}&limit=${model.limit}" 
               hx-get="${model.fragmentUrl}?q=${if (model.searchQuery != null) model.searchQuery else ""}&year=${if (model.selectedYear != null) model.selectedYear.toString() else ""}&offset=${model.nextOffset}&limit=${model.limit}"
               hx-target="#message-list-panel"
               hx-swap="outerHTML"
               hx-push-url="true"
               class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">Next</a>
        @endif
    </div>
</section>
