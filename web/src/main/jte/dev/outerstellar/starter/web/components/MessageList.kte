@import dev.outerstellar.starter.web.MessageListViewModel
@import java.time.LocalDate
@param model: MessageListViewModel

<section class="panel" id="message-list-panel">
    <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        <h2 class="mb-0">${model.messagesHeading}</h2>
        
        <form hx-get="${model.searchActionUrl}" 
              hx-target="#message-list-panel" 
              hx-swap="outerHTML" 
              hx-trigger="keyup changed delay:500ms from:input, change from:select"
              hx-push-url="true"
              class="flex gap-2 items-center">
            <div class="relative">
                <i class="ri-search-line absolute left-3 top-1/2 -translate-y-1/2 opacity-50"></i>
                <input type="text" name="q" value="${model.searchQuery}" placeholder="Search messages..." 
                       class="pl-10 pr-4 py-2 border rounded-lg focus:ring-2 focus:ring-accent outline-none transition-all">
            </div>
            
            <select name="year" class="px-4 py-2 border rounded-lg bg-transparent outline-none cursor-pointer">
                <option value="">All years</option>
                @for (year in (LocalDate.now().year downTo 2024))
                    <option value="${year}" selected="${model.selectedYear == year}">${year}</option>
                @endfor
            </select>
            
            <i class="ri-loader-4-line animate-spin htmx-indicator ml-2 text-accent text-xl"></i>
        </form>
    </div>

    <div class="message-list">
        @if (model.messages.isEmpty())
            <p class="text-center py-12 opacity-50 italic">No messages found matching your criteria.</p>
        @else
            @for (message in model.messages)
                <div class="message-card p-4 border rounded-xl hover:shadow-lg transition-all group relative">
                    <div class="flex justify-between items-start mb-2">
                        <div class="flex items-center gap-2">
                            <i class="ri-user-smile-line text-accent"></i>
                            <strong class="text-lg">${message.author}</strong>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-xs opacity-40 group-hover:opacity-100 transition-opacity">${message.updatedAtLabel()}</span>
                            <button class="text-danger opacity-0 group-hover:opacity-100 transition-all hover:scale-110"
                                    hx-get="${message.confirmDeleteUrl()}"
                                    hx-target="body"
                                    hx-swap="beforeend">
                                <i class="ri-delete-bin-7-line"></i>
                            </button>
                        </div>
                    </div>
                    <p class="opacity-80 leading-relaxed">${message.content}</p>
                </div>
            @endfor
        @endif
    </div>

    <div class="mt-8 flex justify-center gap-4">
        @if (model.prevPageUrl != null)
            <a href="${model.prevPageUrl}" 
               hx-get="${model.prevPageUrl}" 
               hx-target="#message-list-panel" 
               hx-swap="outerHTML"
               hx-push-url="true"
               class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">Previous</a>
        @endif
        
        @if (model.nextPageUrl != null)
            <a href="${model.nextPageUrl}" 
               hx-get="${model.nextPageUrl}" 
               hx-target="#message-list-panel" 
               hx-swap="outerHTML"
               hx-push-url="true"
               class="px-4 py-2 bg-gray-200 rounded hover:bg-gray-300">Next</a>
        @endif
    </div>
</section>
