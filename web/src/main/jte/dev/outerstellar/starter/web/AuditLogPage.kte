@import dev.outerstellar.starter.web.AuditLogPage
@import dev.outerstellar.starter.web.Page

@param model: Page<AuditLogPage>

@template.dev.outerstellar.starter.web.Layout(shell = model.shell, content = @`
    @template.dev.outerstellar.starter.web.components.PageHeader(
        title = model.data.title
    )

    <section class="panel">
        <table class="data-table">
            <thead>
                <tr>
                    <th>${model.data.headerWhen}</th>
                    <th>${model.data.headerActor}</th>
                    <th>${model.data.headerAction}</th>
                    <th>${model.data.headerTarget}</th>
                    <th>${model.data.headerDetail}</th>
                </tr>
            </thead>
            <tbody>
                @for (entry in model.data.entries)
                    <tr>
                        <td style="white-space:nowrap;">${entry.timestamp}</td>
                        <td>${entry.actorUsername}</td>
                        <td><span class="chip">${entry.action}</span></td>
                        <td>${entry.targetUsername}</td>
                        <td>${entry.detail}</td>
                    </tr>
                @endfor
            </tbody>
        </table>

        @template.dev.outerstellar.starter.web.components.Pagination(
            hasPrevious = model.data.hasPrevious,
            hasNext = model.data.hasNext,
            previousUrl = model.data.previousUrl,
            nextUrl = model.data.nextUrl,
            currentPage = model.data.currentPage,
            previousLabel = model.data.previousLabel,
            nextLabel = model.data.nextLabel
        )
    </section>
`)
