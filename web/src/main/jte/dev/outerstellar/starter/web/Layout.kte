@import dev.outerstellar.starter.web.ShellView
@import gg.jte.Content
@param shell: ShellView
@param content: Content

<!DOCTYPE html>
<html lang="${shell.localeTag}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>${shell.pageTitle} - ${shell.appTitle}</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <link rel="stylesheet" href="/site.css?v=${shell.version}">
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <script src="https://unpkg.com/htmx-ext-ws@2.0.1/ws.js"></script>
    <style>
        .htmx-indicator { display: none; }
        .htmx-request .htmx-indicator { display: inline-block; }
        .htmx-request.htmx-indicator { display: inline-block; }

        #toast-container {
            position: fixed;
            top: 1.5rem;
            right: 1.5rem;
            z-index: 9999;
            pointer-events: none;
            width: 320px;
        }
    </style>
</head>
<body class="${shell.layoutClass}" hx-ext="ws" ws-connect="/ws/sync">
<style id="theme-style">${shell.themeCss}</style>
<div id="toast-container"></div>
<script>
    document.addEventListener('htmx:responseError', function(event) {
        const errorBody = event.detail.xhr.responseText || 'An unexpected error occurred';
        showToast(errorBody, 'error');
    });

    function showToast(message, type) {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        toast.className = "panel animate-in slide-in-from-right-10 fade-in duration-300 " + (type === 'error' ? 'panel-danger' : 'panel-success');
        toast.style.padding = '0.75rem 1.25rem';
        toast.style.marginBottom = '0.75rem';
        toast.style.pointerEvents = 'auto';
        toast.style.boxShadow = '0 10px 15px -3px rgba(0, 0, 0, 0.1)';

        const title = type === 'error' ? 'Error' : 'Success';
        const icon = type === 'error' ? 'ri-error-warning-fill' : 'ri-checkbox-circle-fill';

        const row = document.createElement('div');
        row.style.cssText = 'display: flex; align-items: center; gap: 0.75rem;';

        const iconEl = document.createElement('i');
        iconEl.className = icon;
        iconEl.style.fontSize = '1.25rem';

        const textEl = document.createElement('div');

        const titleEl = document.createElement('strong');
        titleEl.style.cssText = 'display: block; font-size: 0.9rem;';
        titleEl.textContent = title;

        const msgEl = document.createElement('p');
        msgEl.style.cssText = 'margin:0; font-size: 0.85rem; opacity: 0.9;';
        msgEl.textContent = message;

        textEl.appendChild(titleEl);
        textEl.appendChild(msgEl);
        row.appendChild(iconEl);
        row.appendChild(textEl);
        toast.appendChild(row);

        container.appendChild(toast);
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(20px)';
            toast.style.transition = 'all 0.3s ease-out';
            setTimeout(() => toast.remove(), 300);
        }, 5000);
    }
</script>
<div class="shell">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <a href="/" class="logo">
                <i class="ri-planet-fill"></i>
                ${shell.appTitle}
            </a>
        </div>
        <nav class="nav-links">
            @for (link in shell.navLinks)
                <a class="nav-link@if (link.active) active@endif" href="${link.url}">
                    <i class="${link.icon}" style="font-size: 1.1rem; opacity: 0.8; margin-right: 0.5rem; width: 20px; text-align: center;"></i>
                    ${link.label}
                </a>
            @endfor
        </nav>
        <div class="sidebar-footer" ws-subscribe>
            <section class="sidebar-select-wrapper">
                <div id="theme-selector"
                     hx-get="${shell.themeSelectorUrl}"
                     hx-trigger="load"
                     hx-swap="innerHTML">
                </div>
            </section>
            <section class="sidebar-select-wrapper">
                <div id="language-selector"
                     hx-get="${shell.languageSelectorUrl}"
                     hx-trigger="load"
                     hx-swap="innerHTML">
                </div>
            </section>
            <section class="sidebar-select-wrapper" style="padding-bottom: 0; margin-bottom: 0;">
                <div id="layout-selector"
                     hx-get="${shell.layoutSelectorUrl}"
                     hx-trigger="load"
                     hx-swap="innerHTML">
                </div>
            </section>
        </div>
    </aside>
    <div class="main-shell">
        <header class="topbar">
            <div style="display: flex; flex-direction: column;">
                <span class="topbar-label">${shell.pageTitle}</span>
                <strong>${shell.appTagline}</strong>
            </div>
            @if(shell.isLoggedIn)
                <div class="topbar-user">
                    <div class="user-info">
                        <span class="user-name">${shell.userName}</span>
                        <div style="display:flex; gap:0.5rem; align-items:center;">
                            @if(shell.profileUrl != null)
                                <a href="${shell.profileUrl}" class="sign-out-link" style="font-size:0.8rem;"><i class="ri-user-settings-line"></i> Profile</a>
                                <span style="opacity:0.3;">|</span>
                            @endif
                            @if(shell.changePasswordUrl != null)
                                <a href="${shell.changePasswordUrl}" class="sign-out-link" style="font-size:0.8rem;"><i class="ri-lock-password-line"></i> Change password</a>
                                <span style="opacity:0.3;">|</span>
                            @endif
                            <form method="post" action="${shell.logoutUrl}" style="display:inline;">
                                <button type="submit" class="sign-out-link" style="background:none;border:none;padding:0;cursor:pointer;">Sign out</button>
                            </form>
                        </div>
                    </div>
                    <div class="user-avatar">
                        <i class="ri-user-smile-line"></i>
                    </div>
                </div>
            @endif
        </header>
        <main class="content">
            <div id="ws-updates" ws-subscribe></div>
            ${content}
        </main>
        <footer class="footer">
            <span>${shell.footerCopy}</span>
            <div id="footer-status"
                 class="chip"
                 hx-get="${shell.footerStatusUrl}"
                 hx-trigger="load"
                 hx-swap="innerHTML">
            </div>
        </footer>
    </div>
</div>
</body>
</html>
