@import dev.outerstellar.starter.web.ShellView
@import gg.jte.Content
@param shell: ShellView
@param content: Content

<!DOCTYPE html>
<html lang="${shell.localeTag}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>${shell.pageTitle} - ${shell.appTitle}</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <link rel="stylesheet" href="/site.css">
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <script src="https://unpkg.com/htmx-ext-ws@2.0.1/ws.js"></script>
    <style>${shell.themeCss}</style>
    <style>
        .htmx-indicator { display: none; }
        .htmx-request .htmx-indicator { display: inline-block; }
        .htmx-request.htmx-indicator { display: inline-block; }

        #toast-container {
            position: fixed;
            top: 1.5rem;
            right: 1.5rem;
            z-index: 9999;
            pointer-events: none;
            width: 320px;
        }
    </style>
</head>
<body class="${shell.layoutClass}" hx-ext="ws" ws-connect="/ws/sync">
<div id="toast-container"></div>
<script>
    document.addEventListener('htmx:responseError', function(event) {
        const errorBody = event.detail.xhr.responseText || 'An unexpected error occurred';
        showToast(errorBody, 'error');
    });

    function showToast(message, type) {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        toast.className = "panel animate-in slide-in-from-right-10 fade-in duration-300 " + (type === 'error' ? 'panel-danger' : 'panel-success');
        toast.style.padding = '0.75rem 1.25rem';
        toast.style.marginBottom = '0.75rem';
        toast.style.pointerEvents = 'auto';
        toast.style.boxShadow = '0 10px 15px -3px rgba(0, 0, 0, 0.1)';
        
        const title = type === 'error' ? 'Error' : 'Success';
        const icon = type === 'error' ? 'ri-error-warning-fill' : 'ri-checkbox-circle-fill';
        
        toast.innerHTML = '<div style="display: flex; align-items: center; gap: 0.75rem;">' +
                '<i class="' + icon + '" style="font-size: 1.25rem;"></i>' +
                '<div>' +
                    '<strong style="display: block; font-size: 0.9rem;">' + title + '</strong>' +
                    '<p style="margin:0; font-size: 0.85rem; opacity: 0.9;">' + message + '</p>' +
                '</div>' +
            '</div>';
        
        container.appendChild(toast);
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(20px)';
            toast.style.transition = 'all 0.3s ease-out';
            setTimeout(() => toast.remove(), 300);
        }, 5000);
    }
</script>
<div class="shell">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <a href="/" class="logo">
                <i class="ri-planet-fill"></i>
                ${shell.appTitle}
            </a>
        </div>
        <nav class="nav-links">
            @for (link in shell.navLinks)
                <a class="nav-link@if (link.active) active@endif" href="${link.url}">
                    <i class="${link.icon}" style="font-size: 1.1rem; opacity: 0.8; margin-right: 0.5rem; width: 20px; text-align: center;"></i>
                    ${link.label}
                </a>
            @endfor
        </nav>
        <div class="sidebar-footer" ws-subscribe>
            @if(shell.isLoggedIn)
                <section class="sidebar-section" style="border-bottom: 1px solid var(--border-subtle); padding-bottom: 1rem; margin-bottom: 1rem;">
                    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                        <i class="ri-user-smile-line" style="font-size: 1.25rem; opacity: 0.7;"></i>
                        <div>
                            <span style="display: block; font-size: 0.85rem; font-weight: 600;">${shell.userName}</span>
                            <a href="${shell.logoutUrl}" style="font-size: 0.75rem; opacity: 0.6; text-decoration: underline;">Sign out</a>
                        </div>
                    </div>
                </section>
            @endif
            <section class="sidebar-section">
                <div id="theme-selector"
                     hx-get="${shell.themeSelectorUrl}"
                     hx-trigger="load"
                     hx-swap="innerHTML">
                </div>
            </section>
            <section class="sidebar-section">
                <div id="language-selector"
                     hx-get="${shell.languageSelectorUrl}"
                     hx-trigger="load"
                     hx-swap="innerHTML">
                </div>
            </section>
            <section class="sidebar-section" style="padding-bottom: 0;">
                <div id="layout-selector"
                     hx-get="${shell.layoutSelectorUrl}"
                     hx-trigger="load"
                     hx-swap="innerHTML">
                </div>
            </section>
        </div>
    </aside>
    <div class="main-shell">
        <header class="topbar">
            <div>
                <p class="topbar-label">${shell.pageTitle}</p>
                <strong>${shell.appTagline}</strong>
            </div>
            <span class="status-badge">${shell.themeId} / ${shell.localeTag}</span>
        </header>
        <main class="content">
            <div id="ws-updates" ws-subscribe></div>
            ${content}
        </main>
        <footer class="footer">
            <span>${shell.footerCopy}</span>
            <div id="footer-status"
                 class="chip"
                 hx-get="${shell.footerStatusUrl}"
                 hx-trigger="load"
                 hx-swap="innerHTML">
            </div>
        </footer>
    </div>
</div>
</body>
</html>
