@import dev.outerstellar.starter.web.UserAdminPage
@import dev.outerstellar.starter.web.Page

@param model: Page<UserAdminPage>

@template.dev.outerstellar.starter.web.Layout(shell = model.shell, content = @`
    @template.dev.outerstellar.starter.web.components.PageHeader(
        title = model.data.title,
        description = model.data.description,
        breadcrumb = model.shell.pageTitle
    )

    <section class="panel">
        <table class="data-table">
            <thead>
                <tr>
                    <th>${model.data.headerUsername}</th>
                    <th>${model.data.headerEmail}</th>
                    <th>${model.data.headerRole}</th>
                    <th class="th-center">${model.data.headerEnabled}</th>
                    <th class="th-center">${model.data.headerActions}</th>
                </tr>
            </thead>
            <tbody>
                @for (user in model.data.users)
                    <tr>
                        <td>${user.username}</td>
                        <td>${user.email}</td>
                        <td><span class="chip">${user.role}</span></td>
                        <td class="td-center">
                            @if(user.enabled)
                                <i class="ri-checkbox-circle-fill" style="color: var(--color-accent);"></i>
                            @else
                                <i class="ri-close-circle-fill" style="color: var(--text-danger, #ef4444);"></i>
                            @endif
                        </td>
                        <td class="td-center">
                            @if(!user.isSelf)
                                <form method="post" action="${user.toggleEnabledUrl}" style="display: inline;">
                                    <button type="submit" class="secondary" style="font-size: 0.8rem; padding: 0.25rem 0.5rem;">
                                        @if(user.enabled)${model.data.actionDisable}@else${model.data.actionEnable}@endif
                                    </button>
                                </form>
                                <form method="post" action="${user.toggleRoleUrl}" style="display: inline;">
                                    <button type="submit" class="secondary" style="font-size: 0.8rem; padding: 0.25rem 0.5rem;">
                                        @if(user.role == "ADMIN")${model.data.actionDemote}@else${model.data.actionPromote}@endif
                                    </button>
                                </form>
                            @else
                                <span class="text-muted" style="font-size: 0.8rem;">(${model.data.selfLabel})</span>
                            @endif
                        </td>
                    </tr>
                @endfor
            </tbody>
        </table>

        @template.dev.outerstellar.starter.web.components.Pagination(
            hasPrevious = model.data.hasPrevious,
            hasNext = model.data.hasNext,
            previousUrl = model.data.previousUrl,
            nextUrl = model.data.nextUrl,
            currentPage = model.data.currentPage,
            previousLabel = model.data.previousLabel,
            nextLabel = model.data.nextLabel
        )
    </section>
`)
