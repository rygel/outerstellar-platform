@import dev.outerstellar.starter.web.UserAdminPage
@import dev.outerstellar.starter.web.Page
@param model: Page<UserAdminPage>

@template.dev.outerstellar.starter.web.Layout(shell = model.shell, content = @`
    <section class="hero-grid">
        <div class="panel">
            <p class="topbar-label">${model.shell.pageTitle}</p>
            <h1>${model.data.title}</h1>
            <p class="text-muted">${model.data.description}</p>
        </div>
    </section>

    <section class="panel">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr>
                    <th style="text-align: left; padding: 0.5rem;">Username</th>
                    <th style="text-align: left; padding: 0.5rem;">Email</th>
                    <th style="text-align: left; padding: 0.5rem;">Role</th>
                    <th style="text-align: center; padding: 0.5rem;">Enabled</th>
                    <th style="text-align: center; padding: 0.5rem;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @for (user in model.data.users)
                    <tr style="border-top: 1px solid var(--border-color, #333);">
                        <td style="padding: 0.5rem;">${user.username}</td>
                        <td style="padding: 0.5rem;">${user.email}</td>
                        <td style="padding: 0.5rem;">
                            <span class="chip">${user.role}</span>
                        </td>
                        <td style="text-align: center; padding: 0.5rem;">
                            @if(user.enabled)
                                <i class="ri-checkbox-circle-fill" style="color: var(--success-color, green);"></i>
                            @else
                                <i class="ri-close-circle-fill" style="color: var(--danger-color, red);"></i>
                            @endif
                        </td>
                        <td style="text-align: center; padding: 0.5rem;">
                            @if(!user.isSelf)
                                <form method="post" action="${user.toggleEnabledUrl}" style="display: inline;">
                                    <button type="submit" class="secondary" style="font-size: 0.8rem; padding: 0.25rem 0.5rem;">
                                        @if(user.enabled)Disable@elseEnable@endif
                                    </button>
                                </form>
                                <form method="post" action="${user.toggleRoleUrl}" style="display: inline;">
                                    <button type="submit" class="secondary" style="font-size: 0.8rem; padding: 0.25rem 0.5rem;">
                                        @if(user.role == "ADMIN")Demote@elsePromote@endif
                                    </button>
                                </form>
                            @else
                                <span class="text-muted" style="font-size: 0.8rem;">(you)</span>
                            @endif
                        </td>
                    </tr>
                @endfor
            </tbody>
        </table>
    </section>
`)
